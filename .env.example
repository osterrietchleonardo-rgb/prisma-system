# CONFIGURACIÓN COMPLETA - PRISMA IA (.env.example)

# SUPABASE (Públicas)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# SUPABASE (Server Side Only - SECRETO)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui
SUPABASE_PROJECT_REF=tu-project-ref-aqui

# GOOGLE GEMINI (Server Side Only - SECRETO)
GEMINI_API_KEY=tu-gemini-api-key-aqui

# TOKKO BROKER (Server Side Only - SECRETO)
# La API se suministra por inmobiliaria en el config, pero podés setear una global aquí.
TOKKO_API_BASE_URL=https://tokkobroker.com/api/v1

# APP CONFIG (Públicas)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="PRISMA IA"
