# CONFIGURACIÓN COMPLETA - PRISMA IA (.env.example)

# SUPABASE (Públicas)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# SUPABASE (Server Side Only - SECRETO)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui
SUPABASE_PROJECT_REF=tu-project-ref-aqui

# GOOGLE GEMINI (Server Side Only - SECRETO)
GEMINI_API_KEY=tu-gemini-api-key-aqui

# TOKKO BROKER (Server Side Only - SECRETO)
# La API se suministra por inmobiliaria en el config, pero podés setear una global aquí.
TOKKO_API_BASE_URL=https://tokkobroker.com/api/v1

# EVOLUTION API — WhatsApp
EVOLUTION_API_URL=https://tu-evolution-api.example.com
NEXT_PUBLIC_EVOLUTION_API_URL=https://tu-evolution-api.example.com
EVOLUTION_API_KEY=tu-evolution-api-key
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu-webhook-verify-token
NEXT_PUBLIC_WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu-webhook-verify-token
BOT_REPLY_SECRET=tu-bot-reply-secret

# N8N — Automatizacion IA
N8N_WEBHOOK_URL=https://tu-n8n.example.com/webhook/whatsapp-incoming
N8N_REPLY_SECRET=una-clave-secreta-compartida-con-n8n

# APP CONFIG (Publicas)
NEXT_PUBLIC_APP_URL=https://prisma.vakdor.com
NEXT_PUBLIC_APP_NAME="PRISMA IA"
